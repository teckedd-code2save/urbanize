# Database Configuration
DATABASE_URL=postgresql://urbanize_user:urbanize_pass@localhost:5432/urbanize
POSTGRES_USER=urbanize_user
POSTGRES_PASSWORD=urbanize_pass
POSTGRES_DB=urbanize

# Clerk Configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/map
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/map

# Mapbox Configuration
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN

# Google Maps Platform — server-side only (never NEXT_PUBLIC_)
# Required for: Google Places POI data (worker) + feature click enrichment
# Get key at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New)
GOOGLE_MAPS_API_KEY=

# Google Earth Engine — server-side only
# Required for: Google Open Buildings V3 (better building data for Ghana/Africa)
# GEE_SERVICE_ACCOUNT_JSON: paste the full contents of a service account JSON key
#   (IAM role needed: roles/earthengine.viewer on the GEE-enabled project)
# GEE_PROJECT: Google Cloud project ID with Earth Engine API enabled
GEE_SERVICE_ACCOUNT_JSON=
GEE_PROJECT=

# HERE Traffic API — server-side only
# Required for: real-time traffic speed & congestion metrics
# Get key at: https://developer.here.com → Projects → REST API
# Enable: Traffic API
HERE_API_KEY=
