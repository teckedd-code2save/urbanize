# .env.schema — required environment variables for urbanize
# Convoy validates presence (not values) before each deploy.

# Postgres connection string (app + worker both read this)
DATABASE_URL=postgres://user:pass@host:5432/urbanize

# Redis connection string (worker queue + cache)
REDIS_URL=redis://host:6379

# Public base URL of the deployed app (used by Next.js for absolute URLs)
NEXT_PUBLIC_APP_URL=https://urbanize.fly.dev
