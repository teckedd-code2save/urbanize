# Required environment variables for urbanize on Fly.io
# Convoy validates these are set before promoting traffic.

# Postgres connection string (managed instance — not the docker-compose local one)
DATABASE_URL=postgres://user:pass@host:5432/urbanize

# Redis connection string (used by worker/ for queue processing)
REDIS_URL=redis://default:pass@host:6379

# Runtime mode — keep as production on Fly
NODE_ENV=production
